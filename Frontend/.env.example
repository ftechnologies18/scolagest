# Variables d'environnement — Next.js (frontend)
# Copier ce fichier en .env et adapter les valeurs.

# ===== Production =====
# URL absolue du backend (Render). Si définie, les appels API utilisent cette URL.
# Si vide (développement sandbox), les appels passent par la gateway Caddy (?XTransformPort=8080).
NEXT_PUBLIC_API_BASE_URL=https://scolagest-backend.onrender.com

# ===== Développement (sandbox local) =====
# Laisser NEXT_PUBLIC_API_BASE_URL vide pour utiliser la gateway Caddy locale.
# NEXT_PUBLIC_API_BASE_URL=

# Base de données Prisma (config scaffold, non utilisée en production)
DATABASE_URL=file:/home/z/my-project/db/custom.db
