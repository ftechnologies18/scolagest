# Variables d'environnement — Backend Go
# Copier ce fichier en .env et adapter les valeurs.

# Port d'écoute du backend Go
PORT=8080

# Base de données — deux modes :
# 1. PostgreSQL (production) : définir DATABASE_URL (Neon, Supabase, etc.)
#    Si défini, PostgreSQL est utilisé (ignorer DB_PATH)
# 2. SQLite (développement local) : laisser DATABASE_URL vide, utiliser DB_PATH
DATABASE_URL=

# Chemin SQLite (développement local seulement — ignoré si DATABASE_URL est défini)
DB_PATH=./data/scolagest.db

# Secret JWT — OBLIGATOIRE à changer en production (chaîne aléatoire longue)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Durée de vie des tokens (en heures)
JWT_ACCESS_EXP_HR=1
JWT_REFRESH_EXP_HR=168

# Environnement : development | production
APP_ENV=development
