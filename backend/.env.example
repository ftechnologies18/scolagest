# Variables d'environnement — Backend Go
# Copier ce fichier en .env et adapter les valeurs.

# Port d'écoute du backend Go
PORT=8080

# Base de données — deux modes :
# 1. PostgreSQL (production) : définir DATABASE_URL (Neon, Supabase, etc.)
#    Si défini, PostgreSQL est utilisé (ignorer DB_PATH)
# 2. SQLite (développement local) : laisser DATABASE_URL vide, utiliser DB_PATH
DATABASE_URL=

# Chemin SQLite (développement local seulement — ignoré si DATABASE_URL est défini)
DB_PATH=./data/scolagest.db

# Secret JWT — OBLIGATOIRE à changer en production (chaîne aléatoire longue)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Durée de vie des tokens (en heures)
JWT_ACCESS_EXP_HR=1
JWT_REFRESH_EXP_HR=168

# Environnement : development | production
APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Emails — transport (par ordre de priorité)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Resend (API REST, recommandé en production) — si RESEND_API_KEY est défini,
#    Resend est utilisé (le SMTP ci-dessous est ignoré).
#    Dashboard : https://resend.com — vérifier le domaine expéditeur avant prod.
# 2. SMTP (fallback) — utilisé seulement si RESEND_API_KEY est vide.
# 3. Mode dev (log only) — si ni Resend ni SMTP n'est configuré.

# Resend (transport principal)
# Domaine vérifié sur Resend : scolagest.ftci.fr (dashboard https://resend.com/domains)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=ScolaGest <noreply@scolagest.ftci.fr>

# URL publique du frontend (pour les liens absolus dans les emails : reset
# password, suivi de pré-inscription, etc.). En production, mettre l'URL
# publique du frontend.
FRONTEND_URL=http://localhost:3000

# SMTP (fallback — utilisé seulement si RESEND_API_KEY est vide)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@scolagest.ftci.fr
